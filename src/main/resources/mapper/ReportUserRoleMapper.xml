<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cyn.udas.mapper.ReportUserRoleMapper">

    <insert id="insert" parameterType="com.cyn.udas.entity.ReportUserRole">
        INSERT INTO tb_report_user_role
            (report_code,user_account,role_type,create_by)
        VALUES
            (#{reportCode},#{userAccount},#{roleType},#{createBy})
    </insert>

    <select id="getByReportAndAccount" resultType="com.cyn.udas.entity.ReportUserRole">
        SELECT * FROM tb_report_user_role
        WHERE report_code = #{reportCode}
          AND user_account = #{account}
          AND del_flag = 0
            LIMIT 1
    </select>

</mapper>
