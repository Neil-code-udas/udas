<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cyn.udas.mapper.ReportCommonMapper">

    <update id="executeCreateTable">
        ${sql}
    </update>

    <select id="selectDynamicDataList" resultType="java.util.Map">
        SELECT * FROM ${tableName} ${whereSql}
            LIMIT #{offset},#{pageSize}
    </select>

    <select id="selectDynamicDataCount" resultType="int">
        SELECT COUNT(*) FROM ${tableName} ${whereSql}
    </select>

    <update id="dynamicLogicDelete">
        UPDATE ${tableName}
        SET del_flag = 1,update_by = #{updateBy},update_time = NOW()
        WHERE id = #{id} AND del_flag = 0
    </update>

</mapper>
